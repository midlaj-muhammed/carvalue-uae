# CarValue UAE — Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/carvalue

# ML Model
MODEL_PATH=../ml/model.pkl
MODEL_CACHE_DIR=../ml/registry

# CORS
